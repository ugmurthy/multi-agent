# ─── Model Provider API Keys ─────────────────────────────────────────────────
# At least one provider is required. Ollama needs no key.

# OpenRouter (https://openrouter.ai/keys)
OPENROUTER_API_KEY=

# Mistral (https://console.mistral.ai/api-keys)
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-2506

# ─── Tool API Keys ──────────────────────────────────────────────────────────
# Configure `web_search` to use `brave` or `duckduckgo`.

# WEB_SEARCH_PROVIDER=brave
# WEB_SEARCH_PROVIDER=duckduckgo
# WEB_TOOL_TIMEOUT_MS=90000
# MODEL_TIMEOUT_MS=90000
# MODEL_TIMEOUT_MS=0

# Brave Search (https://api.search.brave.com/app/keys)
BRAVE_SEARCH_API_KEY=

# ─── Optional Overrides ─────────────────────────────────────────────────────
# Ollama base URL (defaults to http://localhost:11434/v1)
# OLLAMA_BASE_URL=http://localhost:11434/v1

# Default model per provider (used by the sample script)
# OLLAMA_MODEL=qwen3.5
# OPENROUTER_MODEL=anthropic/claude-sonnet-4
# MISTRAL_MODEL=mistral-large-latest
# AGENT_LOG_LEVEL=info
# LOG_DEST=console
# LOG_DEST=file
# LOG_DEST=both
# LOG_DIR=./logs
# AGENT_MAX_STEPS=60
# MODEL_TIMEOUT_MS=90000
# Set MODEL_TIMEOUT_MS=0 to disable the agent-side model timeout.
