{
  "server": {
    "host": "0.0.0.0",
    "port": 3000,
    "websocketPath": "/ws",
    "healthPath": "/health",
    "requestLogging": true,
    "requestLoggingDestination": "both"
  },
  "auth": {
    "provider": "jwt",
    "settings": {
      "secret": "change-me-in-production",
      "algorithms": ["HS256"]
    }
  },
  "cron": {
    "enabled": false,
    "schedulerLeaseMs": 60000,
    "maxConcurrentJobs": 5
  },
  "transcript": {
    "recentMessageWindow": 20,
    "summaryTriggerWindow": 40,
    "summaryMaxMessages": 100,
    "summaryLineMaxLength": 200
  },
  "channels": {
    "defaults": { "sessionConcurrency": 1 },
    "list": [
      { "id": "web", "name": "Web Chat" },
      { "id": "api", "name": "API", "allowedInvocationModes": ["run"] }
    ]
  },
  "bindings": [
    { "match": { "channelId": "web" }, "agentId": "support-agent" },
    { "match": { "channelId": "api" }, "agentId": "support-agent" }
  ],
  "defaultAgentId": "support-agent",
  "hooks": {
    "failurePolicy": "warn",
    "modules": [],
    "onAuthenticate": [],
    "onSessionResolve": [],
    "beforeRoute": [],
    "beforeInboundMessage": [],
    "beforeRunStart": [],
    "afterRunResult": [],
    "onAgentEvent": [],
    "beforeOutboundFrame": [],
    "onDisconnect": [],
    "onError": []
  }
}
