{
  "name": "@adaptive-agent/gateway-fastify",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "bun build ./src/index.ts --outdir dist --target bun",
    "client:local": "bun run ./src/local-ws-client.ts",
    "client:tui": "bun run ./src/local-ws-client-tui.ts",
    "mint:local-jwt": "bun run ./src/mint-local-jwt.ts",
    "start:local": "bun run ./src/start-local.ts",
    "test": "bunx vitest run",
    "test:watch": "bunx vitest",
    "typecheck": "bunx tsc --noEmit"
  },
  "dependencies": {
    "@adaptive-agent/core": "workspace:*",
    "@fastify/websocket": "^11.2.0",
    "@mariozechner/pi-tui": "^0.66.1",
    "chalk": "^5.5.0",
    "fastify": "^5.6.1",
    "jose": "^6.2.2"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "bun-types": "^1.3.5",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  }
}
